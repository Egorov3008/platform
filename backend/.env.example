# === Database ===
DATABASE_URL=postgresql://vpn_user:changeme@localhost:5432/vpn_db

# === Security ===
BOT_SECRET_KEY=generate-a-strong-secret-32-chars
ADMIN_API_KEY=generate-a-strong-secret-32-chars
INVITE_TOKEN=changeme

# === 3x-UI Panel ===
API_URL=http://your-panel:2095
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password

# === YooKassa ===
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxx
DISABLE_WEBHOOK_IP_CHECK=false

# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token
BOT_NAME=MyVPNBot
SUPPORT_CHAT_URL=https://t.me/support_chat
URL_BOT=https://t.me/MyVPNBot

# === Bot Behaviour ===
ADMIN_ID=[123456789]
AVAILABLE_RATES=[9, 8, 7]
AVAILABLE_CONNECTIONS=[11, 12]
DEFAULT_PRICING_PLAN=10
TRIAL_TIME=30
DISCOUNTS=3

# === Logging ===
LOG_LEVEL=INFO

# === Monitoring ===
METRICS_PORT=9101
