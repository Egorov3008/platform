# ===================================================================
# UNIFIED ENVIRONMENT CONFIGURATION FOR VPN PLATFORM
# ===================================================================
#
# SETUP: Copy this file to .env and update all values for your environment
#
# All services (backend, bot, web) load variables from the root .env file:
#   $ cp .env.example .env
#   $ vim .env                    # Edit configuration values
#   $ docker-compose up -d        # Services read from .env automatically
#
# Environment variables are shared across all components via docker-compose.
# Do NOT create .env files in subdirectories (backend/, bot/, web/).
# ===================================================================

# === PostgreSQL (local development) ===
DB_NAME=vpn_bot
DB_USER=vpn_user
DB_PASSWORD=changeme

# === Database URL (all services) ===
DATABASE_URL=postgresql://vpn_user:changeme@localhost:5432/vpn_bot

# === Security (shared across all services) ===
BOT_SECRET_KEY=generate-a-strong-secret-32-chars
ADMIN_API_KEY=generate-a-strong-secret-32-chars
SECRET_KEY=test-secret-key-that-is-long-enough
INVITE_TOKEN=web_invite_2026

# === 3x-UI Panel ===
XUI_API_URL=http://your-panel:2095
XUI_LOGIN=admin
XUI_PASSWORD=admin_password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password
XUI_SERVER_ID=1
XUI_SUB=https://your-domain.com:2096
XUI_WEB_BASE_PATH=/

# === Landing page (Telegram-доступ без регистрации) ===
# ID отдельного inbound в 3x-UI, оптимизированного под Telegram.
# Должен быть ТАКЖЕ добавлен в AVAILABLE_CONNECTIONS ниже.
XUI_INBOUND_ID_LANDING=0
# HMAC-секрет для подписи куки tg_landing_id (90 дней).
# Если пусто — используется BOT_SECRET_KEY.
LANDING_COOKIE_SECRET=
# Публичный URL лендинга (для OpenGraph и мета-тегов).
LANDING_PUBLIC_URL=https://telegram.example.com

# === YooKassa (Payment Processing) ===
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxx
DISABLE_WEBHOOK_IP_CHECK=false

# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
BOT_NAME=MyVPNBot
TELEGRAM_BOT_USERNAME=your_bot_username
SUPPORT_CHAT_URL=https://t.me/support_chat
URL_BOT=https://t.me/your_bot_username

# === Bot Behavior ===
ADMIN_ID=[123456789]
ADMIN_TG_IDS=[123456789]
AVAILABLE_RATES=[9, 8, 7]
AVAILABLE_CONNECTIONS=[11, 12]  # + добавить XUI_INBOUND_ID_LANDING, если он отличается
DEFAULT_PRICING_PLAN=10
# Telegram-only grace window (дни) после истечения платной подписки:
# overlay (AVAILABLE_CONNECTIONS) открепляется, остаётся только
# XUI_INBOUND_ID_LANDING. 0 = отключить grace. См. grace-модель в backend/CLAUDE.md.
GRACE_PERIOD_DAYS=7
TRIAL_TIME=30
DISCOUNTS=3
PAYMENT_INFO={}

# === Webhook Configuration ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=5001
WEBHOOK_PATH=/api/v1/payments/webhook
WEBHOOK_BASE_URL=https://your-domain.com
# Если 443 занят (напр. 3x-UI), webhook публикуется на публичном 8443 напрямую
# (без PROXY-протокола). 8443 — один из портов, разрешённых YooKassa.
# WEBHOOK_BASE_URL=https://your-domain.com:8443

# Safety net для пропущенных webhook'ов YooKassa: фоновый опрос pending-платежей
# (каждые 15 мин) и маршрутизация succeeded. Только платежи младше этого окна (мин).
PAYMENT_SWEEP_MAX_AGE_MINUTES=1440
# CSV payment_id, которые авто-поллинг пропускает (уже обработаны вручную без
# обновления статуса — чтобы не продлить ключ повторно).
PAYMENT_SWEEP_EXCLUDE_IDS=

# === Web API ===
BACKEND_URL=http://localhost:8000
CSRF_ENABLED=true

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=
LOG_FORMAT=detailed

# === Monitoring ===
METRICS_PORT=9101
