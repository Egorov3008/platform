# === PostgreSQL (для docker-compose) ===
DB_NAME=vpn_db
DB_USER=vpn_user
DB_PASSWORD=changeme

# === Backend (копировать в backend/.env) ===
# DATABASE_URL=postgresql://vpn_user:changeme@localhost:5432/vpn_db
# BOT_SECRET_KEY=generate-a-strong-secret
# ADMIN_API_KEY=generate-a-strong-secret
# LOG_LEVEL=INFO
# XUI_API_URL=http://your-panel:2095
# XUI_LOGIN=admin
# XUI_PASSWORD=admin_password
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=test_xxxxx
# WEBHOOK_BASE_URL=https://your-domain.com

# === Bot (копировать в bot/.env) ===
# BOT_TOKEN=your_telegram_bot_token
# DATABASE_URL=postgresql://vpn_user:changeme@localhost:5432/vpn_db
# ADMIN_ID=[123456789]
# (остальные переменные — см. bot/.env.example)

# === Web (копировать в web/.env) ===
# DATABASE_URL=postgresql://vpn_user:changeme@localhost:5432/vpn_db
# SECRET_KEY=generate-a-strong-secret
# BACKEND_URL=http://backend:8000
# BOT_SECRET_KEY=generate-a-strong-secret (тот же что у backend)
