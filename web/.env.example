# Web environment variables

# === Database (auth tables only) ===
DATABASE_URL=postgresql://user:password@localhost:5432/vpn_db

# === Security ===
SECRET_KEY=your-secret-key-that-is-long-enough
BOT_SECRET_KEY=your-bot-secret-key
INVITE_TOKEN=web_invite_2026

# === Backend API ===
BACKEND_URL=http://localhost:8000

# === YooKassa ===
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret-key

# === 3x-UI Panel ===
XUI_API_URL=http://localhost
XUI_LOGIN=admin
XUI_PASSWORD=admin

# === Webhook ===
WEBHOOK_BASE_URL=http://localhost

# === Admin ===
ADMIN_TG_IDS=[123456789]

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

# === Features ===
CSRF_ENABLED=true

# === Available Rates ===
AVAILABLE_RATES=[7, 8, 9]

# === Logging ===
LOG_LEVEL=INFO
