# ===================================================================
# DEV ENVIRONMENT — .env.dev
# ===================================================================
# Copy this to .env.dev (already named so) and fill real test secrets.
# Never commit secrets.
#
# This file is used ONLY by docker-compose.dev.yml and dev helper scripts.
# ===================================================================

# === PostgreSQL (dev container, host port 5434) ===
DB_NAME=vpn_bot_dev
DB_USER=vpn_user_dev
DB_PASSWORD=changeme_dev_very_strong

# === Database URL (used by local scripts; compose overrides host to postgres_dev) ===
DATABASE_URL=postgresql://vpn_user_dev:changeme_dev_very_strong@127.0.0.1:5434/vpn_bot_dev

# === Security (dev only, different from prod) ===
BOT_SECRET_KEY=dev-bot-secret-32-chars-minimum
ADMIN_API_KEY=dev-admin-api-key-32-chars-minimum
SECRET_KEY=dev-secret-key-that-is-long-enough
INVITE_TOKEN=web_invite_2026_dev

# === 3x-UI Panel (TEST panel, never prod) ===
XUI_API_URL=http://your-test-panel:2095
XUI_LOGIN=admin
XUI_PASSWORD=admin_password
XUI_SUB=http://your-test-panel:2096
XUI_SERVER_ID=1
XUI_SKIP_SSL_VERIFY=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password

# === YooKassa (TEST credentials only) ===
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxx
DISABLE_WEBHOOK_IP_CHECK=true
RECEIPT_CUSTOMER_EMAIL=dev@example.com

# === Telegram Bot (TEST bot from @BotFather) ===
BOT_TOKEN=your_test_telegram_bot_token
TELEGRAM_BOT_TOKEN=your_test_telegram_bot_token
BOT_NAME=MyVPNBotDev
TELEGRAM_BOT_USERNAME=your_test_bot_username
SUPPORT_CHAT_URL=https://t.me/support_chat
URL_BOT=https://t.me/your_test_bot_username

# === Bot Behavior ===
ADMIN_ID=[123456789]
ADMIN_TG_IDS=[123456789]
AVAILABLE_RATES=[9, 8, 7]
AVAILABLE_CONNECTIONS=[11, 12]
DEFAULT_PRICING_PLAN=10
# Telegram-only grace window (дни) после истечения платной подписки (0 = disable).
GRACE_PERIOD_DAYS=7
TRIAL_TIME=30
DISCOUNTS=3
PAYMENT_INFO={"test": "value"}

# === Webhook Configuration (YooKassa -> backend) ===
# Set WEBHOOK_BASE_URL after running `make dev-ngrok` or scripts/update_ngrok_webhook.sh.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/api/v1/payments/webhook
WEBHOOK_BASE_URL=https://your-ngrok-domain.ngrok-free.app

# === Web API ===
BACKEND_URL=http://127.0.0.1:8000
USE_HOST_BACKEND=false
CSRF_ENABLED=true
CAPTCHA_SECRET=dev-captcha-secret

# === Logging ===
LOG_LEVEL=DEBUG
LOG_FILE=
LOG_FORMAT=detailed

# === Monitoring ===
METRICS_PORT=9101
